# ─── Mock Data Configuration ─────────────────────────────────────────────────
# Set USE_MOCK to false when the backend is ready
VITE_USE_MOCK=true

# Choose mock user role for testing:
#   CLIENT_ADMIN  - Business admin (Chidi Okonkwo) - Full permissions
#   CLIENT_USER   - Business user (Ngozi Eze) - Read-only permissions
#   AEGIS_ADMIN   - Platform super-admin (Emeka Adeyemi) - Aegis admin
VITE_MOCK_USER_ROLE=CLIENT_ADMIN

# ─── API Configuration ───────────────────────────────────────────────────────
# Backend API base URL (uncomment and modify if needed)
# VITE_API_BASE_URL=http://localhost:5000/api/v1

# Base64-encoded 32-byte AES key used to encrypt protected auth payloads.
# Must match PAYLOAD_ENCRYPTION_KEY configured in Portal API.
# Generate with: openssl rand -base64 32
# VITE_PAYLOAD_ENCRYPTION_KEY=
