# ─── Mock Data Configuration ─────────────────────────────────────────────────
# Set USE_MOCK to false when the backend is ready
VITE_USE_MOCK=true

# Choose mock user role for testing:
#   CLIENT_ADMIN  - Business admin (Chidi Okonkwo) - Full permissions
#   CLIENT_USER   - Business user (Ngozi Eze) - Read-only permissions
#   AEGIS_ADMIN   - Platform super-admin (Emeka Adeyemi) - Aegis admin
VITE_MOCK_USER_ROLE=CLIENT_ADMIN

# ─── API Configuration ───────────────────────────────────────────────────────
